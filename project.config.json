{
  "description": "积木堆叠小游戏 - 请在微信开发者工具中使用测试号或填写真实 AppID",
  "packOptions": {
    "ignore": [
      { "type": "file", "value": "audio/README.txt" }
    ],
    "include": []
  },
  "setting": {
    "bundle": false,
    "userConfirmedBundleSwitch": false,
    "urlCheck": true,
    "scopeDataCheck": false,
    "coverView": true,

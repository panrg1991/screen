.container {
  width: 100%;
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  position: relative;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

/* 背景装饰 */
.bg-decoration {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 0;
}

.bg-circle {
  position: absolute;
  border-radius: 50%;
  opacity: 0.08;
}

.c1 {
  width: 500rpx;
  height: 500rpx;
  background: #667eea;
  top: -150rpx;
  right: -150rpx;
}

.c2 {
  width: 400rpx;
  height: 400rpx;
  background: #e94560;
  bottom: -100rpx;
  left: -100rpx;
}

/* 结果内容 */
.result-content {
  position: relative;
  z-index: 1;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 40rpx;
  box-sizing: border-box;
  animation: fadeIn 0.5s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(40rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* 图标 */
.result-icon {
  margin-bottom: 30rpx;
}

.icon-text {
  font-size: 120rpx;
}

/* 标题 */
.result-title {
  font-size: 52rpx;
  font-weight: 900;
  color: #fff;
  margin-bottom: 10rpx;
}

.result-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 50rpx;
}

/* 得分卡片 */
.score-card {
  width: 100%;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 30rpx;
  padding: 50rpx 40rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  margin-bottom: 50rpx;
}

.score-main {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.score-main .score-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 10rpx;
}

.score-main .score-value {
  font-size: 80rpx;
  font-weight: 900;
  background: linear-gradient(135deg, #ffd700, #ff6b6b);
  -webkit-background-clip: text;
  color: transparent;
}

/* 得分详情 */
.score-details {
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 30rpx 0;
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
}

.detail-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.detail-value {
  font-size: 40rpx;
  font-weight: 900;
  color: #667eea;
  margin-bottom: 6rpx;
}

.detail-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}

.detail-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.1);
}

/* 星级评价 */
.stars {
  display: flex;
  justify-content: center;
  gap: 30rpx;
  margin-top: 30rpx;
  padding-top: 30rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
}

.star {
  font-size: 60rpx;
  color: rgba(255, 255, 255, 0.15);
  transition: all 0.3s;
}

.star.active {
  color: #ffd700;
  text-shadow: 0 0 20rpx rgba(255, 215, 0, 0.6);
}

/* 新纪录 */
.new-best {
  text-align: center;
  margin-top: 20rpx;
  font-size: 30rpx;
  color: #e94560;
  font-weight: bold;
  animation: pulse 1.5s infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

/* 操作按钮 */
.action-btns {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: bold;
  letter-spacing: 4rpx;
}

.primary-btn {
  background: linear-gradient(135deg, #e94560, #c23152);
  color: #fff;
  box-shadow: 0 8rpx 32rpx rgba(233, 69, 96, 0.4);
}

.secondary-btn {
  background: rgba(255, 255, 255, 0.1);
  color: rgba(255, 255, 255, 0.7);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

/* 分享按钮 */
.share-btn {
  width: 80% !important;
  background: linear-gradient(135deg, #667eea, #764ba2) !important;
  color: #fff !important;
  font-size: 28rpx !important;
  font-weight: bold !important;
  border-radius: 40rpx !important;
  padding: 20rpx 0 !important;
  border: none !important;
  line-height: 1.5 !important;
}

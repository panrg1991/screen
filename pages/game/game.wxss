.game-container {
  width: 100%;
  height: 100vh;
  background: #1a1a2e;
  position: relative;
  overflow: hidden;
}

/* 顶部状态栏 */
.status-bar {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 80rpx 30rpx 20rpx;
  background: linear-gradient(180deg, rgba(26,26,46,0.95) 0%, rgba(26,26,46,0) 100%);
  z-index: 10;
  box-sizing: border-box;
}

.status-left {
  flex: 0 0 120rpx;
}

.back-btn {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  padding: 10rpx 0;
}

.status-center {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 20rpx;
}

.level-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 10rpx;
}

.progress-bar {
  width: 100%;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #667eea, #e94560);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.status-right {
  flex: 0 0 120rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.score-text {
  font-size: 40rpx;
  font-weight: 900;
  color: #ffd700;
  text-shadow: 0 0 10rpx rgba(255, 215, 0, 0.5);
}

.score-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 连击提示 */
.combo-display {
  position: fixed;
  top: 200rpx;
  left: 50%;
  transform: translateX(-50%) scale(0);
  z-index: 5;
  opacity: 0;
  transition: all 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55);
}

.combo-display.show {
  transform: translateX(-50%) scale(1);
  opacity: 1;
}

.combo-text {
  font-size: 48rpx;
  font-weight: 900;
  color: #ffd700;
  text-shadow: 0 0 20rpx rgba(255, 215, 0, 0.8);
}

/* 完美提示 */
.perfect-display {
  position: fixed;
  top: 280rpx;
  left: 50%;
  transform: translateX(-50%) scale(0) rotate(-10deg);
  z-index: 5;
  opacity: 0;
  transition: all 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
}

.perfect-display.show {
  transform: translateX(-50%) scale(1) rotate(0deg);
  opacity: 1;
}

.perfect-text {
  font-size: 56rpx;
  font-weight: 900;
  background: linear-gradient(135deg, #ffd700, #ff6b6b);
  -webkit-background-clip: text;
  color: transparent;
}

/* 游戏画布 */
.game-canvas {
  width: 100%;
  height: 100%;
}

/* 底部信息 */
.bottom-info {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  display: flex;
  justify-content: space-around;
  padding: 20rpx 40rpx 60rpx;
  background: linear-gradient(0deg, rgba(26,26,46,0.95) 0%, rgba(26,26,46,0) 100%);
  z-index: 10;
  box-sizing: border-box;
}

.info-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.info-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 4rpx;
}

.info-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}

/* 游戏结束后显示的提示（可选） */

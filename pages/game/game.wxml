<view class="game-container">
  <!-- 顶部状态栏 -->
  <view class="status-bar">
    <view class="status-left">
      <view class="back-btn" bindtap="onBack">
        <text>← 返回</text>
      </view>
    </view>
    <view class="status-center">
      <text class="level-text">第{{level}}关 · {{difficultyName}}</text>
      <view class="progress-bar">
        <view class="progress-fill" style="width: {{progress}}%"></view>
      </view>
    </view>
    <view class="status-right">
      <text class="score-text">{{score}}</text>
      <text class="score-label">得分</text>
    </view>
  </view>

  <!-- 连击提示 -->
  <view class="combo-display {{combo > 1 ? 'show' : ''}}" wx:if="{{combo > 1}}">
    <text class="combo-text">{{combo}} 连击!</text>
  </view>

  <!-- 完美提示 -->
  <view class="perfect-display {{showPerfect ? 'show' : ''}}" wx:if="{{showPerfect}}">
    <text class="perfect-text">✨ 完美! ✨</text>
  </view>

  <!-- 游戏画布 -->
  <canvas
    type="2d"
    id="gameCanvas"
    class="game-canvas"
    bindtouchstart="onTap"
  ></canvas>

  <!-- 底部信息 -->
  <view class="bottom-info">
    <view class="info-item">
      <text class="info-label">已叠</text>
      <text class="info-value">{{currentLayer}}/{{targetLayers}}</text>
    </view>
    <view class="info-item">
      <text class="info-label">完美</text>
      <text class="info-value">{{perfectCount}}</text>
    </view>
    <view class="info-item">
      <text class="info-label">最高</text>
      <text class="info-value">{{bestScore}}</text>
    </view>
  </view>
</view>

.container {
  width: 100%;
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  padding: 0 40rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

/* 背景装饰 */
.bg-decoration {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 0;
}

.bg-circle {
  position: absolute;
  border-radius: 50%;
  opacity: 0.1;
}

.c1 {
  width: 400rpx;
  height: 400rpx;
  background: #667eea;
  top: -100rpx;
  right: -100rpx;
}

.c2 {
  width: 300rpx;
  height: 300rpx;
  background: #764ba2;
  bottom: 200rpx;
  left: -80rpx;
}

.c3 {
  width: 200rpx;
  height: 200rpx;
  background: #e94560;
  bottom: -50rpx;
  right: 100rpx;
}

/* 标题区域 */
.title-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
  margin-bottom: 50rpx;
  position: relative;
  z-index: 1;
}

.game-icon {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 20rpx;
}

.block {
  border-radius: 8rpx;
  box-shadow: 0 4rpx 8rpx rgba(0,0,0,0.3);
}

.b1 {
  width: 80rpx;
  height: 30rpx;
  background: #667eea;
  margin-bottom: 4rpx;
}

.b2 {
  width: 70rpx;
  height: 30rpx;
  background: #764ba2;
  margin-bottom: 4rpx;
}

.b3 {
  width: 60rpx;
  height: 30rpx;
  background: #e94560;
}

.title {
  font-size: 72rpx;
  font-weight: 900;
  background: linear-gradient(135deg, #667eea, #764ba2, #e94560);
  -webkit-background-clip: text;
  color: transparent;
  letter-spacing: 8rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
  letter-spacing: 12rpx;
  margin-top: 10rpx;
}

/* 区块通用 */
.section {
  position: relative;
  z-index: 1;
  margin-bottom: 40rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 20rpx;
  padding-left: 10rpx;
}

/* 难度选择 */
.difficulty-list {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.difficulty-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 10rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.difficulty-item.active {
  background: rgba(102, 126, 234, 0.2);
  border-color: #667eea;
  box-shadow: 0 0 30rpx rgba(102, 126, 234, 0.3);
}

.diff-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.diff-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 6rpx;
}

.diff-desc {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 关卡选择 */
.level-list {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.level-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 180rpx;
  padding: 24rpx 16rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  border: 2rpx solid transparent;
  position: relative;
  transition: all 0.3s;
}

.level-item.active {
  background: rgba(233, 69, 96, 0.2);
  border-color: #e94560;
  box-shadow: 0 0 30rpx rgba(233, 69, 96, 0.3);
}

.level-item.locked {
  opacity: 0.4;
}

.level-num {
  font-size: 48rpx;
  font-weight: 900;
  color: #667eea;
}

.level-label {
  font-size: 26rpx;
  color: #fff;
  margin: 6rpx 0;
}

.level-target {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}

.level-best {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #ffd700;
}

.lock-icon {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 48rpx;
}

.level-arrow {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.3);
  margin: 0 4rpx;
}

.locked-arrow {
  font-size: 24rpx;
}

/* 开始按钮 */
.start-btn {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 80%;
  height: 100rpx;
  margin: 40rpx auto;
  background: linear-gradient(135deg, #e94560 0%, #c23152 100%);
  border-radius: 50rpx;
  font-size: 36rpx;
  font-weight: 900;
  color: #fff;
  letter-spacing: 8rpx;
  box-shadow: 0 10rpx 40rpx rgba(233, 69, 96, 0.5);
  animation: pulse 2s infinite;
}

.start-btn:active {
  transform: scale(0.95);
  animation: none;
}

/* 底部 */
.footer {
  position: relative;
  z-index: 1;
  display: flex;
  justify-content: center;
  padding: 30rpx 0 60rpx;
}

.footer-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
  text-decoration: underline;
}

/* 帮助弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.modal-content {
  width: 80%;
  background: linear-gradient(180deg, #1a1a2e, #16213e);
  border-radius: 30rpx;
  padding: 50rpx 40rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.1);
}

.modal-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 40rpx;
  color: #fff;
}

.help-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.help-item {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.6;
}

.modal-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 60%;
  height: 80rpx;
  margin: 40rpx auto 0;
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-radius: 40rpx;
  font-size: 30rpx;
  color: #fff;
  font-weight: bold;
}
